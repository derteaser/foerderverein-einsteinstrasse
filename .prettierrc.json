{
    "plugins": ["@prettier/plugin-php", "@shufo/prettier-plugin-blade", "prettier-plugin-tailwindcss"],
    "phpVersion": "8.3",
    "singleQuote": true,
    "trailingCommaPHP": true,
    "braceStyle": "1tbs",
    "printWidth": 120,
    "overrides": [
        {
            "files": "*.blade.php",
            "options": {
                "parser": "blade"
            }
        }
    ]
}
